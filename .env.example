# Neon PostgreSQL
DATABASE_URL=postgresql://username:password@ep-xxx.neon.tech/neondb?sslmode=require

# Auth / App
JWT_SECRET=your_very_long_random_secret_minimum_32_chars
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_botfather
TELEGRAM_WEBHOOK_SECRET=your_random_webhook_secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email messaging (Resend)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@example.com
RESEND_FROM_NAME=ITRobotics

# Optional cron / integrations
CRON_SECRET=your_cron_secret
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key
MEDIA_BOT_TOKEN=your_media_bot_token_from_botfather
MEDIA_BOT_SECRET=your_random_hmac_secret_64_chars
TELEGRAM_SCHOOL_GROUP_ID=-100xxxxxxxxxx
GOOGLE_DRIVE_ROOT_FOLDER_ID=your_drive_folder_id
GOOGLE_OAUTH_CLIENT_ID=your_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_oauth_client_secret
GOOGLE_OAUTH_REFRESH_TOKEN=your_refresh_token
